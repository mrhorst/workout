{
  "name": "workout",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "workout": "./bin/workout.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "SKILL.md"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "node scripts/clean-build.mjs && tsc -p tsconfig.build.json && vite build",
    "cli": "npm run build --silent && node dist/cli.js",
    "dashboard": "npm run build --silent && node dist/cli.js serve",
    "prepare": "npm run build",
    "start": "node dist/cli.js serve",
    "test": "npm run build --silent && tsc -p tsconfig.test.json && node --test dist-test/*.test.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^5.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "vite": "^8.0.16"
  }
}
